# Same value as SUBMIT_API_KEY on Vercel (frontend build variable).
# In local dev you can omit this if SUBMIT_API_KEY is set — Vite maps it automatically.
VITE_SUBMIT_API_KEY=replace-with-a-long-random-string


# Optional. Omit when app and API are on the same Vercel domain.
# VITE_SHEETS_SUBMIT_URL=https://your-app.vercel.app/api/append-production

SUBMIT_API_KEY=
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_LOG_TAB_NAME=
GOOGLE_SHEET_DAILY_TAB_NAME=
