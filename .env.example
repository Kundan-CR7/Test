# Vercel → Project → Settings → Environment Variables
# Never commit credentials.json or real keys to git.

SUBMIT_API_KEY=replace-with-a-long-random-string

# Spreadsheet ID from: https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEETS_ID=your-spreadsheet-id

# Two tabs in the same spreadsheet (create both tab names in Google Sheets)
GOOGLE_SHEET_LOG_TAB_NAME=Logs
GOOGLE_SHEET_DAILY_TAB_NAME=Daily

# Legacy alias for log tab only
# GOOGLE_SHEET_TAB_NAME=Logs

# --- Option A (easiest): paste your entire credentials.json as ONE line ---
# Minify the JSON file (no line breaks), paste as the value:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"punjab-cncs",...}

# --- Option B: separate fields from credentials.json ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=main-service-account@punjab-cncs.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"